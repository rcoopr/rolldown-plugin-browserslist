{
  "name": "rolldown-plugin-browserslist",
  "version": "1.0.0",
  "description": "Configure rolldown's transform target based on a browserslist query",
  "license": "MIT",
  "author": "Ross Cooper <ross@liveheats.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcoopr/rolldown-plugin-browserslist.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "test": "vitest",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "node --run build && node --run lint && node --run test -- --no-watch",
    "prepare": "node --run build"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "oxlint": "^1.62.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@nihalgonsalves/esconfig": "^0.17.3",
    "@types/debug": "^4.1.13",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "browserslist": "^4.28.2",
    "esbuild": "^0.28.0",
    "esbuild-plugin-browserslist": "^3.0.2",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint-tsgolint": "^0.22.1",
    "rolldown": "^1.0.0-rc.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "browserslist": "^4.28.2",
    "rolldown": "^1.0.0-rc.18"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >23.0.0"
  },
  "packageManager": "yarn@4.13.0"
}
